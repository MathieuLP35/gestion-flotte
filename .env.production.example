# ---------------------------------------------------------------------------
# .env production — à copier en .env sur le serveur dans DEPLOY_PATH
# Ne pas commiter le .env réel.
# ---------------------------------------------------------------------------

APP_NAME="Gestion Flotte"
APP_ENV=production
APP_KEY=base64:xxx  # php artisan key:generate
APP_DEBUG=false
APP_URL=http://${{ secrets.SERVER_IP }}

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr

SESSION_DRIVER=database
SESSION_LIFETIME=120
BROADCAST_CONNECTION=reverb
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- MySQL (obligatoire en prod avec ce docker-compose) ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=change_me

# Pour le healthcheck MySQL
MYSQL_ROOT_PASSWORD=change_me_root

# --- Reverb (WebSockets) ---
REVERB_APP_ID=1
REVERB_APP_KEY=your_key
REVERB_APP_SECRET=your_secret
REVERB_HOST=${{ secrets.SERVER_IP }}
REVERB_PORT=80
REVERB_SCHEME=http

# --- Build Docker (Vite) — utilisés à la construction de l’image sur le VPS ---
VITE_APP_NAME="${APP_NAME}"
# REVERB_* ci‑dessus sont aussi utilisés au build.

# --- Optionnel ---
# MAIL_*, AWS_*, etc.
